{
  "$schema": "https://railway.app/railpack.schema.json",
  "build": {
    "steps": [
      { "run": "composer install --optimize-autoloader --no-scripts --no-interaction" },
      { "run": "npm ci" },
      { "run": "npm prune --omit=dev --ignore-scripts" },
      { "run": "npm run build" },
      { "run": "mkdir -p storage/framework/{sessions,views,cache,testing} storage/logs bootstrap/cache && chmod -R a+rw storage" },
      { "run": "php artisan config:cache --no-interaction" },
      { "run": "php artisan route:cache" },
      { "run": "php artisan view:cache" }
    ]
  },
  "deploy": {
    "steps": [
      { "run": "/start-container.sh" }
    ]
  }
}
